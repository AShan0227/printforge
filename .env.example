# PrintForge v2.2 Environment Variables

# HuggingFace token (for Hunyuan3D cloud inference, optional)
HF_TOKEN=

# JWT secret for API auth (auto-generated if not set)
PRINTFORGE_JWT_SECRET=

# Feishu webhook URL for generation notifications (optional)
PRINTFORGE_FEISHU_WEBHOOK=

# TripoSR device (auto-detected: mps > cuda > cpu)
# PRINTFORGE_DEVICE=mps
